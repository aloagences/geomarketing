# ===========================================
# Configuration des clés API (côté serveur)
# ===========================================
# Copiez ce fichier en .env et remplissez vos clés.
# Ne commitez JAMAIS le fichier .env sur GitHub !

# OpenRouter (Recommandé - Modèles gratuits)
OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini
GEMINI_API_KEY=AIzaSy...

# Groq
GROQ_API_KEY=gsk_...

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Mistral AI
MISTRAL_API_KEY=...
